# Private IPv4 of the reverse-proxy Caddy instance on the shared VPC private
# network. Yopass uses this to validate the X-Forwarded-For header and trust
# the client IP that Caddy injects.
#
# Get it with:
#   cd ~/nevin-platform-infra && make sandbox-output reverse_proxy_private_ipv4
# (or `tofu state show module.reverse_proxy.scaleway_instance_server.this`
#  and copy the private_ip).
REVERSE_PROXY_PRIVATE_IP=10.0.0.0
